# Copy this file to `.env` and fill in the values you need.
# Only ANTHROPIC_API_KEY is required; everything else has a sensible default.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key. Used by the LangGraph ReAct chat agent and the
# Haiku-powered enrichment pass. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: chat model ──────────────────────────────────────────────────────

# Override the chat agent model. Defaults to claude-sonnet-4-6.
# CHAT_MODEL=claude-sonnet-4-6

# Max output tokens per chat turn. Defaults to 8192.
# CHAT_MAX_TOKENS=8192

# ── Optional: bundle I/O directories ──────────────────────────────────────────

# Where to look for input Excel files (modelling + scoping sheets) per org.
# Defaults to <repo>/resources/input.
# BUNDLE_INPUT_ROOT=/absolute/path/to/inputs

# Where generated bundle ZIPs are written.
# Defaults to <repo>/resources/output.
# BUNDLE_OUTPUT_ROOT=/absolute/path/to/outputs

# ── Optional: LangSmith tracing (cost + latency dashboard) ────────────────────

# Set LANGSMITH_TRACING=true AND provide an API key to ship traces to
# https://smith.langchain.com. When tracing is on, the REPL banner shows
# "LangSmith: tracing → project '<name>'" on startup.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=avni-ai-tools
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # EU: https://eu.api.smith.langchain.com

# ── Optional: logging ─────────────────────────────────────────────────────────

# File-log threshold. Defaults to INFO (captures per-form enrichment
# progress). Set to DEBUG for everything, WARNING for just problems.
# Console output is always WARNING+ regardless, so the chat REPL stays clean.
# LOG_LEVEL=INFO

# Where diagnostic logs are written (relative paths resolve against repo root).
# Defaults to <repo>/logs/avni.log with rotation at 5 MB × 3 backups.
# LOG_FILE=logs/avni.log

# ── Optional: avni-ai-web (FastAPI service) ───────────────────────────────────
#
# Only required when running `avni-ai-web` — the chat REPL and the rules CLI
# ignore these. See specs/AVNI_WEBAPP_INTEGRATION_SDD.md for the full design.

# Base URL of the avni-server instance the service forwards auth checks and
# bundle uploads to. Required for the web service.
# AVNI_SERVER_BASE_URL=https://staging.avniproject.org

# Origin the React UI is served from — used for the FastAPI CORS allowlist.
# In dev this is typically http://localhost:6010 (avni-webapp's default port).
# Comma-separate to allow multiple origins.
# AI_WEBAPP_ORIGIN=http://localhost:6010

# Where per-session input + output bundles are written. One subdirectory per
# session id. Cleaned up by the reaper on session expiry.
# AI_SESSION_DIR=/tmp/avni-ai

# Idle threshold (minutes) after which an inactive session is reaped.
# AI_SESSION_IDLE_MIN=30

# Absolute session lifetime (hours). Sessions older than this are reaped
# even if active — defence against runaway tabs.
# AI_SESSION_MAX_HOURS=2

# Port the FastAPI service listens on locally. Default 8090 (avoids the
# avni-server 8080 collision on a typical dev machine). ALBs in front of
# it map 443/80 → this port.
# AI_WEB_PORT=8090
